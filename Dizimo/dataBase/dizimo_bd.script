CREATE SCHEMA PUBLIC AUTHORIZATION DBA
CREATE MEMORY TABLE DIZIMISTA(IDDIZIMISTA INTEGER NOT NULL PRIMARY KEY,NOME VARCHAR_IGNORECASE(100) NOT NULL,DTNASCIMENTO DATE NOT NULL,NOMECONJUGE VARCHAR(100) DEFAULT NULL,ENDERECO VARCHAR(100) DEFAULT NULL,TELEFONE VARCHAR(15) DEFAULT NULL,DTCASAMENTO DATE DEFAULT NULL,IDCONJUGEDIZIMISTA INTEGER,FALECIDO BOOLEAN DEFAULT FALSE NOT NULL,INATIVO BOOLEAN DEFAULT FALSE NOT NULL,CONSTRAINT SYS_FK_50 FOREIGN KEY(IDCONJUGEDIZIMISTA) REFERENCES DIZIMISTA(IDDIZIMISTA))
CREATE MEMORY TABLE USUARIO(IDUSUARIO INTEGER GENERATED BY DEFAULT AS IDENTITY(START WITH 0) NOT NULL PRIMARY KEY,NOME VARCHAR_IGNORECASE(50) NOT NULL,SENHA VARCHAR(15) NOT NULL)
CREATE MEMORY TABLE FINANCEIRO(IDFINANCEIRO INTEGER GENERATED BY DEFAULT AS IDENTITY(START WITH 0) NOT NULL PRIMARY KEY,IDDIZIMISTA INTEGER NOT NULL,VALOR DECIMAL(6,2) NOT NULL,DTLANCAMENTO DATE NOT NULL,ANOMESREFERENCIA INTEGER NOT NULL,CONSTRAINT SYS_FK_57 FOREIGN KEY(IDDIZIMISTA) REFERENCES DIZIMISTA(IDDIZIMISTA) ON DELETE CASCADE)
ALTER TABLE USUARIO ALTER COLUMN IDUSUARIO RESTART WITH 13
ALTER TABLE FINANCEIRO ALTER COLUMN IDFINANCEIRO RESTART WITH 5539
CREATE USER SA PASSWORD ""
GRANT DBA TO SA
SET WRITE_DELAY 0 MILLIS
SET SCHEMA PUBLIC
